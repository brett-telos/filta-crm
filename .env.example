# Replit-provided (auto-injected in Replit deployments)
DATABASE_URL=postgresql://user:pass@host:5432/filta_crm

# App config
NEXT_PUBLIC_APP_NAME=Filta CRM
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Seed admin user (created on first db:seed run)
SEED_ADMIN_EMAIL=brett@telos.ventures
SEED_ADMIN_PASSWORD=change-me-on-first-login
SEED_ADMIN_FIRST_NAME=Brett
SEED_ADMIN_LAST_NAME=Merrill

# Transactional email (Resend). If RESEND_API_KEY is blank the app logs
# would-be sends to the server console and stamps email_sends rows with a
# synthetic "dev_..." provider message id so the UI works end-to-end without
# hitting the network. Drop in a real key to go live.
RESEND_API_KEY=
# Optional — default Reply-To header applied to all outbound sends. Falls back
# to the territory's plus-addressed reply.<domain> address when blank, which
# is what the inbound webhook expects to match replies against.
EMAIL_REPLY_TO=
# Required for the events + inbound webhooks (W4.1). Set to the Svix signing
# secret shown in the Resend webhook config screen — starts with `whsec_`.
# Without this, /api/webhooks/resend/events and /inbound return 503 instead
# of accepting unsigned traffic.
RESEND_WEBHOOK_SECRET=
# Required for W7.0 customer portal links. Should be the public deployed URL
# of the CRM (e.g. https://filta-crm.brett-telos.repl.co or your custom
# domain). Used to compose the /q/[token] and /a/[token] URLs that appear in
# customer-facing emails.
PUBLIC_APP_URL=
# Required for W7.1 scheduled digest emails. Used by external schedulers
# (Replit Scheduled Deployments, cron-job.org, GitHub Actions) to authenticate
# POST /api/digests/run. Generate with: openssl rand -hex 32
# See docs/digests-setup.md for the full setup walkthrough.
DIGEST_SECRET=
