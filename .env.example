# Replit-provided (auto-injected in Replit deployments)
DATABASE_URL=postgresql://user:pass@host:5432/filta_crm

# App config
NEXT_PUBLIC_APP_NAME=Filta CRM
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Seed admin user (created on first db:seed run)
SEED_ADMIN_EMAIL=brett@telos.ventures
SEED_ADMIN_PASSWORD=change-me-on-first-login
SEED_ADMIN_FIRST_NAME=Brett
SEED_ADMIN_LAST_NAME=Merrill

# Transactional email (Resend). If RESEND_API_KEY is blank the app logs
# would-be sends to the server console and stamps email_sends rows with a
# synthetic "dev_..." provider message id so the UI works end-to-end without
# hitting the network. Drop in a real key to go live.
RESEND_API_KEY=
# Optional — default Reply-To header applied to all outbound sends. Falls back
# to the territory's from address when blank.
EMAIL_REPLY_TO=
